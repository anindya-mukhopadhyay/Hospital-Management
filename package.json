{
  "name": "hospital-patient-management-system",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite --config client/vite.config.js --host 127.0.0.1 --port 5173",
    "server": "node --watch server/index.js",
    "build": "vite build --config client/vite.config.js",
    "preview": "vite preview --config client/vite.config.js --host 127.0.0.1 --port 4173",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.12.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "marked": "^18.0.6",
    "prisma": "^6.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.9.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "tsx": "^4.23.1"
  }
}
