generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum PaymentMode {
  CASH
  CARD
  UPI
  INSURANCE
}

model Department {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  doctors Doctor[]
}

model Patient {
  id               Int               @id @default(autoincrement())
  fullName         String
  dateOfBirth      DateTime
  gender           Gender
  bloodGroup       String?
  phone            String
  address          String?
  emergencyContact String?
  createdAt        DateTime          @default(now())
  appointments     Appointment[]
  treatmentRecords TreatmentRecord[]
  bills            Bill[]
}

model Doctor {
  id              Int               @id @default(autoincrement())
  departmentId    Int
  fullName        String
  specialization  String
  phone           String
  email           String?
  consultationFee Decimal           @default(0) @db.Decimal(10, 2)
  active          Boolean           @default(true)
  department      Department        @relation(fields: [departmentId], references: [id])
  appointments    Appointment[]
  treatmentRecords TreatmentRecord[]
}

model TreatmentCatalog {
  code             String            @id
  description      String
  standardCost     Decimal           @db.Decimal(10, 2)
  active           Boolean           @default(true)
  treatmentRecords TreatmentRecord[]
}

model Appointment {
  id            Int               @id @default(autoincrement())
  patientId     Int
  doctorId      Int
  appointmentAt DateTime
  status        AppointmentStatus @default(SCHEDULED)
  reason        String
  notes         String?
  createdAt     DateTime          @default(now())
  patient       Patient           @relation(fields: [patientId], references: [id])
  doctor        Doctor            @relation(fields: [doctorId], references: [id])
  treatments    TreatmentRecord[]

  @@unique([doctorId, appointmentAt])
}

model TreatmentRecord {
  id             Int              @id @default(autoincrement())
  patientId      Int
  doctorId       Int
  appointmentId  Int?
  treatmentCode  String
  diagnosis      String
  prescription   String?
  treatmentDate  DateTime         @default(now())
  quantity       Decimal          @default(1) @db.Decimal(8, 2)
  unitCost       Decimal          @db.Decimal(10, 2)
  billId         Int?
  patient        Patient          @relation(fields: [patientId], references: [id])
  doctor         Doctor           @relation(fields: [doctorId], references: [id])
  appointment    Appointment?     @relation(fields: [appointmentId], references: [id])
  treatment      TreatmentCatalog @relation(fields: [treatmentCode], references: [code])
  bill           Bill?            @relation(fields: [billId], references: [id])
  billItem       BillItem?
}

model Bill {
  id              Int               @id @default(autoincrement())
  patientId       Int
  billDate        DateTime          @default(now())
  subtotal        Decimal           @default(0) @db.Decimal(10, 2)
  discountPercent Decimal           @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal           @default(0) @db.Decimal(10, 2)
  taxPercent      Decimal           @default(5) @db.Decimal(5, 2)
  taxAmount       Decimal           @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal           @default(0) @db.Decimal(10, 2)
  amountPaid      Decimal           @default(0) @db.Decimal(10, 2)
  paymentStatus   PaymentStatus     @default(UNPAID)
  notes           String?
  patient         Patient           @relation(fields: [patientId], references: [id])
  items           BillItem[]
  payments        Payment[]
  treatments      TreatmentRecord[]
}

model BillItem {
  id          Int             @id @default(autoincrement())
  billId      Int
  treatmentId Int             @unique
  description String
  quantity    Decimal         @db.Decimal(8, 2)
  unitCost    Decimal         @db.Decimal(10, 2)
  lineTotal   Decimal         @db.Decimal(10, 2)
  bill        Bill            @relation(fields: [billId], references: [id])
  treatment   TreatmentRecord @relation(fields: [treatmentId], references: [id])
}

model Payment {
  id          Int         @id @default(autoincrement())
  billId      Int
  amount      Decimal     @db.Decimal(10, 2)
  paymentDate DateTime    @default(now())
  paymentMode PaymentMode
  referenceNo String?
  bill        Bill        @relation(fields: [billId], references: [id])
}
